# Copy this file to .env and fill in the real values.
# Never commit .env to git.

# Database
# asyncpg driver required: postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase (Auth + DB)
# Project Settings -> API -> Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Project Settings -> API -> JWT Secret  (NOT the anon key)
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Firebase (FCM push notifications only)
# Path to your Firebase service-account JSON (download from Firebase Console)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-3-5-sonnet-20241022

# App
APP_NAME=FitBuddy API
DEBUG=false

# Workers
PUSH_WORKER_INTERVAL_MINUTES=15
SKIP_RISK_THRESHOLD_HOURS=5
PUSH_COOLDOWN_HOURS=3
